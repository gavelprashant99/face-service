# ── Face Recognition Service — Environment Variables ────────────────
# Copy this file to .env and adjust values for your environment.

# Application
APP_ENV=development                # "development" | "production"
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR

# API auth
API_KEY=your-generated-secret-key  # Bearer token clients must send
                                   # Leave empty to disable auth (dev only)

# Server
HOST=0.0.0.0                       # Bind address
PORT=8001                          # Port to listen on

# CORS (production only — comma-separated origins)
ALLOWED_ORIGINS=https://timesay.in,https://app.timesay.in

# Storage
TEMP_FOLDER=./temp                 # Temp uploads directory
LOCAL_STORAGE_DIR=./storage/employee_faces  # Registered face images
